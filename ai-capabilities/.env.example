# Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=products
QDRANT_FAQ_COLLECTION=faqs

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# Search Configuration
SEARCH_TOP_K=10
BATCH_SIZE=32

# Service URLs
SEARCH_SERVICE_URL=http://search-service:8001
INDEXER_SERVICE_URL=http://indexer-service:8002

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
